# Frontend (required for auth)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Optional compatibility alias (use this only if you prefer anon key naming)
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# API base for local development (optional)
VITE_API_URL=/api

# Backend (required for server-side token verification)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# MongoDB connection URI (optional) - if not set, an in-memory fallback is used for development
MONGODB_URI=mongodb://localhost:27017/gig_guardian

# App port for backend
PORT=8000

# Third-party integration secrets (provide only in production):
# RAZORPAY_KEY=rzp_test_XXXXXXXX
# RAZORPAY_SECRET=your_razorpay_secret
# STRIPE_API_KEY=sk_test_xxx

# Notes:
# - Copy this file to `.env` and fill the production values.
# - Do NOT commit the real `.env` or any secret values into version control.
# - The frontend reads VITE_* vars at build time; backend reads SUPABASE_* and MONGODB_URI at runtime.
